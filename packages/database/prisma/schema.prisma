// Fluxen database schema — Phase 1 scope: auth, workspaces, waitlist.
// Monitoring tables (Website, Scan, PageSnapshot, ...) arrive in Phase 2+.
// Target model documented in docs/DATABASE_SCHEMA.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (Better Auth managed) ----------

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions          Session[]
  accounts          Account[]
  ownedWorkspaces   Workspace[]       @relation("WorkspaceOwner")
  memberships       WorkspaceMember[]
  approvedBaselines Baseline[]        @relation("BaselineApprover")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---------- Workspaces ----------

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  WorkspaceMember[]
  websites Website[]

  @@index([ownerId])
  @@map("workspace")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(OWNER)
  createdAt   DateTime      @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_member")
}

// ---------- Websites & monitored pages (Phase 2) ----------

enum WebsiteStatus {
  PENDING
  DISCOVERING
  BASELINING
  ACTIVE
  PAUSED
  ERROR
}

enum ScanFrequency {
  WEEKLY
  DAILY
}

model Website {
  id            String        @id @default(cuid())
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  url           String
  normalizedUrl String
  status        WebsiteStatus @default(PENDING)
  scanFrequency ScanFrequency @default(WEEKLY)
  timezone      String        @default("UTC")
  lastScanAt    DateTime?
  nextScanAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  monitoredPages MonitoredPage[]
  scans          Scan[]
  baselines      Baseline[]
  changeEvents   ChangeEvent[]

  @@unique([workspaceId, normalizedUrl])
  @@index([workspaceId])
  @@index([status, nextScanAt])
  @@map("website")
}

model MonitoredPage {
  id            String   @id @default(cuid())
  websiteId     String
  website       Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  url           String
  normalizedUrl String
  name          String?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots    PageSnapshot[]
  baselines    Baseline[]
  changeEvents ChangeEvent[]

  @@unique([websiteId, normalizedUrl])
  @@index([websiteId])
  @@map("monitored_page")
}

// ---------- Scans & snapshots (Phase 3) ----------

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
}

enum ScanTriggerType {
  BASELINE
  SCHEDULED
  MANUAL
}

enum LinkType {
  INTERNAL
  EXTERNAL
}

model Scan {
  id              String          @id @default(cuid())
  websiteId       String
  website         Website         @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  status          ScanStatus      @default(QUEUED)
  triggerType     ScanTriggerType
  startedAt       DateTime?
  completedAt     DateTime?
  pagesRequested  Int             @default(0)
  pagesScanned    Int             @default(0)
  pagesFailed     Int             @default(0)
  changesDetected Int             @default(0)
  highestSeverity String?
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime        @default(now())

  snapshots    PageSnapshot[]
  changeEvents ChangeEvent[]

  @@index([websiteId, createdAt(sort: Desc)])
  @@map("scan")
}

model PageSnapshot {
  id                         String   @id @default(cuid())
  scanId                     String
  scan                       Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  monitoredPageId            String
  monitoredPage              MonitoredPage @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  websiteId                  String
  url                        String
  finalUrl                   String?
  httpStatus                 Int?
  responseTimeMs             Int?
  htmlHash                   String?
  domHash                    String?
  textHash                   String?
  screenshotStorageKey       String?
  screenshotHash             String?
  visualDifferencePercentage Float?
  title                      String?
  metaDescription            String?
  canonicalUrl               String?
  robotsMeta                 String?
  h1Values                   Json?
  structuredDataHash         String?
  pageWeightBytes            Int?
  requestCount               Int?
  errorCode                  String?
  errorMessage               String?
  createdAt                  DateTime @default(now())

  links                 PageLink[]
  scripts               PageScript[]
  baselines             Baseline[]
  changesAsPrevious     ChangeEvent[] @relation("ChangePreviousSnapshot")
  changesAsCurrent      ChangeEvent[] @relation("ChangeCurrentSnapshot")

  @@unique([scanId, monitoredPageId])
  @@index([monitoredPageId, createdAt(sort: Desc)])
  @@map("page_snapshot")
}

model PageLink {
  id             String       @id @default(cuid())
  pageSnapshotId String
  pageSnapshot   PageSnapshot @relation(fields: [pageSnapshotId], references: [id], onDelete: Cascade)
  url            String
  normalizedUrl  String
  linkType       LinkType
  statusCode     Int?
  createdAt      DateTime     @default(now())

  @@index([pageSnapshotId])
  @@map("page_link")
}

model PageScript {
  id             String       @id @default(cuid())
  pageSnapshotId String
  pageSnapshot   PageSnapshot @relation(fields: [pageSnapshotId], references: [id], onDelete: Cascade)
  src            String
  domain         String
  scriptHash     String?
  isThirdParty   Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([pageSnapshotId])
  @@map("page_script")
}

// ---------- Baselines (Phase 4) ----------

enum BaselineStatus {
  ACTIVE
  SUPERSEDED
}

model Baseline {
  id               String         @id @default(cuid())
  websiteId        String
  website          Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  monitoredPageId  String
  monitoredPage    MonitoredPage  @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  pageSnapshotId   String
  pageSnapshot     PageSnapshot   @relation(fields: [pageSnapshotId], references: [id], onDelete: Cascade)
  version          Int
  status           BaselineStatus @default(ACTIVE)
  approvedByUserId String?
  approvedByUser   User?          @relation("BaselineApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  createdAt        DateTime       @default(now())

  // One version number per page; the single-ACTIVE-per-page invariant is
  // additionally enforced by a partial unique index (see migration).
  @@unique([monitoredPageId, version])
  @@index([websiteId])
  @@index([monitoredPageId, status])
  @@map("baseline")
}

// ---------- Change events (Phase 5) ----------

enum ChangeCategory {
  AVAILABILITY
  VISUAL
  SEO
  CONTENT
  LINKS
  SCRIPT
  PERFORMANCE
  CONVERSION
}

enum ChangeSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ChangeStatus {
  NEW
  REVIEWED
  APPROVED
  RESOLVED
  IGNORED
}

model ChangeEvent {
  id                 String         @id @default(cuid())
  websiteId          String
  website            Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  monitoredPageId    String
  monitoredPage      MonitoredPage  @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  previousSnapshotId String?
  previousSnapshot   PageSnapshot?  @relation("ChangePreviousSnapshot", fields: [previousSnapshotId], references: [id], onDelete: SetNull)
  currentSnapshotId  String?
  currentSnapshot    PageSnapshot?  @relation("ChangeCurrentSnapshot", fields: [currentSnapshotId], references: [id], onDelete: SetNull)
  scanId             String
  scan               Scan           @relation(fields: [scanId], references: [id], onDelete: Cascade)
  category           ChangeCategory
  changeType         String
  severity           ChangeSeverity
  title              String
  description        String
  previousValue      String?
  currentValue       String?
  metadata           Json?
  status             ChangeStatus   @default(NEW)
  detectedAt         DateTime       @default(now())
  resolvedAt         DateTime?
  approvedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([websiteId, status, severity])
  @@index([monitoredPageId])
  @@index([scanId])
  @@index([detectedAt(sort: Desc)])
  @@map("change_event")
}

// ---------- Waitlist (migrated from Phase 0 file store) ----------

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("unknown")
  createdAt DateTime @default(now())

  @@map("waitlist_entry")
}

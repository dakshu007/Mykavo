// Fluxen database schema — Phase 1 scope: auth, workspaces, waitlist.
// Monitoring tables (Website, Scan, PageSnapshot, ...) arrive in Phase 2+.
// Target model documented in docs/DATABASE_SCHEMA.md.

generator client {
  provider = "prisma-client-js"
  // "native" for local dev; the rhel target is the engine for Netlify/AWS
  // Lambda (Node 20 / OpenSSL 3) where the serverless functions run.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (Better Auth managed) ----------

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions          Session[]
  accounts          Account[]
  ownedWorkspaces   Workspace[]       @relation("WorkspaceOwner")
  memberships       WorkspaceMember[]
  approvedBaselines Baseline[]        @relation("BaselineApprover")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---------- Workspaces ----------

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              WorkspaceMember[]
  websites             Website[]
  notificationChannels NotificationChannel[]
  notifications        Notification[]
  subscription         Subscription?
  checkoutIntents      CheckoutIntent[]
  websiteAddons        WebsiteAddon[]

  @@index([ownerId])
  @@map("workspace")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(OWNER)
  createdAt   DateTime      @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_member")
}

// ---------- Websites & monitored pages (Phase 2) ----------

enum WebsiteStatus {
  PENDING
  DISCOVERING
  BASELINING
  ACTIVE
  PAUSED
  ERROR
}

enum ScanFrequency {
  WEEKLY
  DAILY
}

model Website {
  id            String        @id @default(cuid())
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  url           String
  normalizedUrl String
  status        WebsiteStatus @default(PENDING)
  scanFrequency ScanFrequency @default(WEEKLY)
  timezone      String        @default("UTC")
  lastScanAt    DateTime?
  nextScanAt    DateTime?
  // Maintenance window (spec §25): while in the future, alerts are not sent
  // (change events / incidents still recorded). Null or past = not muted.
  muteAlertsUntil DateTime?
  // Public uptime badge. The opaque token is the ONLY public identifier —
  // website ids must never be exposed publicly. Disabling keeps the token.
  badgeEnabled  Boolean       @default(false)
  publicToken   String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  monitoredPages    MonitoredPage[]
  scans             Scan[]
  baselines         Baseline[]
  changeEvents      ChangeEvent[]
  notifications     Notification[]
  performanceAudits PerformanceAudit[]
  healthChecks      HealthCheck[]
  healthIncidents   HealthIncident[]
  siteMetaSnapshots SiteMetaSnapshot[]

  @@unique([workspaceId, normalizedUrl])
  @@index([workspaceId])
  @@index([status, nextScanAt])
  @@map("website")
}

model MonitoredPage {
  id            String   @id @default(cuid())
  websiteId     String
  website       Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  url           String
  normalizedUrl String
  name          String?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots         PageSnapshot[]
  baselines         Baseline[]
  changeEvents      ChangeEvent[]
  monitoredElements MonitoredElement[]

  @@unique([websiteId, normalizedUrl])
  @@index([websiteId])
  @@map("monitored_page")
}

// ---------- Scans & snapshots (Phase 3) ----------

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
}

enum ScanTriggerType {
  BASELINE
  SCHEDULED
  MANUAL
}

enum LinkType {
  INTERNAL
  EXTERNAL
}

model Scan {
  id              String          @id @default(cuid())
  websiteId       String
  website         Website         @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  status          ScanStatus      @default(QUEUED)
  triggerType     ScanTriggerType
  startedAt       DateTime?
  completedAt     DateTime?
  pagesRequested  Int             @default(0)
  pagesScanned    Int             @default(0)
  pagesFailed     Int             @default(0)
  changesDetected Int             @default(0)
  highestSeverity String?
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime        @default(now())

  snapshots        PageSnapshot[]
  changeEvents     ChangeEvent[]
  notifications    Notification[]
  siteMetaSnapshot SiteMetaSnapshot?

  @@index([websiteId, createdAt(sort: Desc)])
  @@map("scan")
}

// Per-scan capture of site-level SEO infrastructure: robots.txt and the
// sitemap (spec §19 family — "robots.txt Monitoring" / "Sitemap Monitoring").
// One row per scan (plain fetch, no Playwright). Comparison runs against the
// most recent PREVIOUS capture for the website — site meta has no
// user-approved baseline concept, so "previous scan" is the reference.
model SiteMetaSnapshot {
  id        String  @id @default(cuid())
  scanId    String  @unique
  scan      Scan    @relation(fields: [scanId], references: [id], onDelete: Cascade)
  websiteId String
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  // robots.txt observation. Content is capped at 64 KB (truncated with a
  // note); the hash covers the FULL fetched body so change detection is not
  // fooled by truncation. Null status = fetch failed (DNS/timeout/etc.).
  robotsTxtStatus  Int?
  robotsTxtContent String?
  robotsTxtHash    String?

  // Sitemap observation: the candidate URL fetched (first robots.txt
  // declaration, else {origin}/sitemap.xml), its status, total <loc> count
  // (index files expand up to 3 children), and the top-level document hash.
  sitemapUrl      String?
  sitemapStatus   Int?
  sitemapUrlCount Int?
  sitemapHash     String?

  createdAt DateTime @default(now())

  @@index([websiteId, createdAt(sort: Desc)])
  @@map("site_meta_snapshot")
}

model PageSnapshot {
  id                         String   @id @default(cuid())
  scanId                     String
  scan                       Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  monitoredPageId            String
  monitoredPage              MonitoredPage @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  websiteId                  String
  url                        String
  finalUrl                   String?
  httpStatus                 Int?
  responseTimeMs             Int?
  htmlHash                   String?
  domHash                    String?
  textHash                   String?
  screenshotStorageKey       String?
  screenshotHash             String?
  visualDifferencePercentage Float?
  title                      String?
  metaDescription            String?
  canonicalUrl               String?
  robotsMeta                 String?
  h1Values                   Json?
  structuredDataHash         String?
  pageWeightBytes            Int?
  requestCount               Int?
  errorCode                  String?
  errorMessage               String?
  createdAt                  DateTime @default(now())

  links                   PageLink[]
  scripts                 PageScript[]
  baselines               Baseline[]
  changesAsPrevious       ChangeEvent[] @relation("ChangePreviousSnapshot")
  changesAsCurrent        ChangeEvent[] @relation("ChangeCurrentSnapshot")
  monitoredElementResults MonitoredElementResult[]

  @@unique([scanId, monitoredPageId])
  @@index([monitoredPageId, createdAt(sort: Desc)])
  // Retention sweep: expired snapshots per website by age (Phase 10).
  @@index([websiteId, createdAt])
  @@map("page_snapshot")
}

model PageLink {
  id             String       @id @default(cuid())
  pageSnapshotId String
  pageSnapshot   PageSnapshot @relation(fields: [pageSnapshotId], references: [id], onDelete: Cascade)
  url            String
  normalizedUrl  String
  linkType       LinkType
  statusCode     Int?
  createdAt      DateTime     @default(now())

  @@index([pageSnapshotId])
  @@map("page_link")
}

model PageScript {
  id             String       @id @default(cuid())
  pageSnapshotId String
  pageSnapshot   PageSnapshot @relation(fields: [pageSnapshotId], references: [id], onDelete: Cascade)
  src            String
  domain         String
  scriptHash     String?
  isThirdParty   Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([pageSnapshotId])
  @@map("page_script")
}

// ---------- Conversion element monitoring (Phase 9) ----------

enum MonitoredElementImportance {
  NORMAL
  IMPORTANT
  CRITICAL
}

// A business-critical element a user wants watched on a page (e.g. the
// "Start free trial" CTA, a pricing button, a contact form). Checked on every
// scan; a change from the baseline state produces a CONVERSION change event.
model MonitoredElement {
  id                 String                     @id @default(cuid())
  monitoredPageId    String
  monitoredPage      MonitoredPage              @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  name               String
  selector           String
  // Declared expectations. Existence/visibility default to true (the element
  // should be present and shown). expectedText/expectedHref are optional pins:
  // when set, the current value is compared against them instead of the
  // baseline value, giving an absolute guarantee.
  expectedExistence  Boolean                    @default(true)
  expectedVisibility Boolean                    @default(true)
  expectedText       String?
  expectedHref       String?
  importance         MonitoredElementImportance @default(IMPORTANT)
  enabled            Boolean                    @default(true)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  results MonitoredElementResult[]

  @@index([monitoredPageId])
  @@map("monitored_element")
}

// The observed state of a monitored element on a single snapshot. Stored per
// snapshot (like PageLink/PageScript) so comparison is self-contained: the
// baseline snapshot carries the state to diff the current scan against. The
// element's config is copied in so history survives config edits/deletes.
model MonitoredElementResult {
  id                 String                     @id @default(cuid())
  pageSnapshotId     String
  pageSnapshot       PageSnapshot               @relation(fields: [pageSnapshotId], references: [id], onDelete: Cascade)
  // Nullable + SetNull: deleting the config keeps historical results readable.
  monitoredElementId String?
  monitoredElement   MonitoredElement?          @relation(fields: [monitoredElementId], references: [id], onDelete: SetNull)
  name               String
  selector           String
  importance         MonitoredElementImportance
  expectedExistence  Boolean
  expectedVisibility Boolean
  expectedText       String?
  expectedHref       String?
  // Observed state at scan time.
  exists             Boolean
  visible            Boolean
  text               String?
  href               String?
  createdAt          DateTime                   @default(now())

  @@index([pageSnapshotId])
  @@index([monitoredElementId])
  @@map("monitored_element_result")
}

// ---------- Performance audits (Lighthouse) ----------

enum PerformanceAuditStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

// An on-demand Lighthouse audit of a website URL. Category scores are 0–100
// (Lighthouse's 0–1 score × 100); Core Web Vitals are in ms except `cls`
// (unitless). Rows are created QUEUED by the web app and completed by the
// worker.
model PerformanceAudit {
  id                 String                 @id @default(cuid())
  websiteId          String
  website            Website                @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  url                String
  status             PerformanceAuditStatus @default(QUEUED)
  performanceScore   Int?
  accessibilityScore Int?
  bestPracticesScore Int?
  seoScore           Int?
  lcpMs              Int?
  fcpMs              Int?
  tbtMs              Int?
  ttiMs              Int?
  speedIndexMs       Int?
  cls                Float?
  errorCode          String?
  errorMessage       String?
  createdAt          DateTime               @default(now())
  completedAt        DateTime?

  @@index([websiteId, createdAt(sort: Desc)])
  @@map("performance_audit")
}

// ---------- Site health (uptime + SSL expiry) ----------

enum HealthIncidentKind {
  DOWN
  SSL_EXPIRING
}

// One lightweight availability probe of a website's homepage (plain GET, no
// Playwright), recorded by the worker's health sweep every few minutes.
// Up/down rule: up = ANY HTTP response with status < 500 and != 404;
// down = network error, timeout, 5xx, or 404 (see @fluxen/shared isHttpUp).
model HealthCheck {
  id             String    @id @default(cuid())
  websiteId      String
  website        Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  checkedAt      DateTime  @default(now())
  up             Boolean
  httpStatus     Int?
  responseTimeMs Int?
  // Certificate notAfter for https sites; null for http or when the TLS
  // metadata probe fails (never fails the check itself).
  sslValidTo     DateTime?
  errorCode      String?

  @@index([websiteId, checkedAt(sort: Desc)])
  @@map("health_check")
}

// An open (resolvedAt null) or historical health problem. DOWN opens after
// two CONSECUTIVE failed checks (single-blip false-positive guard, spec §25)
// and resolves on the first successful check. SSL_EXPIRING opens when the
// certificate expires within 14 days and resolves once a check sees a
// renewed certificate. lastNotifiedAt rate-limits alerts to once per 24h.
model HealthIncident {
  id             String             @id @default(cuid())
  websiteId      String
  website        Website            @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  kind           HealthIncidentKind
  openedAt       DateTime           @default(now())
  resolvedAt     DateTime?
  lastNotifiedAt DateTime?
  detail         String?

  @@index([websiteId, resolvedAt])
  @@map("health_incident")
}

// ---------- Baselines (Phase 4) ----------

enum BaselineStatus {
  ACTIVE
  SUPERSEDED
}

model Baseline {
  id               String         @id @default(cuid())
  websiteId        String
  website          Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  monitoredPageId  String
  monitoredPage    MonitoredPage  @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  pageSnapshotId   String
  pageSnapshot     PageSnapshot   @relation(fields: [pageSnapshotId], references: [id], onDelete: Cascade)
  version          Int
  status           BaselineStatus @default(ACTIVE)
  approvedByUserId String?
  approvedByUser   User?          @relation("BaselineApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  createdAt        DateTime       @default(now())

  // One version number per page; the single-ACTIVE-per-page invariant is
  // additionally enforced by a partial unique index (see migration).
  @@unique([monitoredPageId, version])
  @@index([websiteId])
  @@index([monitoredPageId, status])
  @@map("baseline")
}

// ---------- Change events (Phase 5) ----------

enum ChangeCategory {
  AVAILABILITY
  VISUAL
  SEO
  CONTENT
  LINKS
  SCRIPT
  PERFORMANCE
  CONVERSION
}

enum ChangeSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ChangeStatus {
  NEW
  REVIEWED
  APPROVED
  RESOLVED
  IGNORED
}

model ChangeEvent {
  id                 String         @id @default(cuid())
  websiteId          String
  website            Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  // Null for site-wide changes (robots.txt / sitemap) that belong to the
  // website rather than a monitored page.
  monitoredPageId    String?
  monitoredPage      MonitoredPage? @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  previousSnapshotId String?
  previousSnapshot   PageSnapshot?  @relation("ChangePreviousSnapshot", fields: [previousSnapshotId], references: [id], onDelete: SetNull)
  currentSnapshotId  String?
  currentSnapshot    PageSnapshot?  @relation("ChangeCurrentSnapshot", fields: [currentSnapshotId], references: [id], onDelete: SetNull)
  scanId             String
  scan               Scan           @relation(fields: [scanId], references: [id], onDelete: Cascade)
  category           ChangeCategory
  changeType         String
  severity           ChangeSeverity
  title              String
  description        String
  previousValue      String?
  currentValue       String?
  metadata           Json?
  status             ChangeStatus   @default(NEW)
  detectedAt         DateTime       @default(now())
  resolvedAt         DateTime?
  approvedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([websiteId, status, severity])
  @@index([monitoredPageId])
  @@index([scanId])
  @@index([detectedAt(sort: Desc)])
  // Retention sweep: expired change events per website by age (Phase 10).
  @@index([websiteId, detectedAt])
  @@map("change_event")
}

// ---------- Notifications (Phase 7) ----------

enum NotificationChannelType {
  EMAIL
  SLACK
  WEBHOOK
  DISCORD
  MICROSOFT_TEAMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model NotificationChannel {
  id            String                  @id @default(cuid())
  workspaceId   String
  workspace     Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type          NotificationChannelType @default(EMAIL)
  enabled       Boolean                 @default(true)
  // { recipients: string[], minSeverity: "MEDIUM" | "HIGH" | "CRITICAL", failureAlerts: boolean }
  configuration Json
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@unique([workspaceId, type])
  @@index([workspaceId])
  @@map("notification_channel")
}

model Notification {
  id           String                  @id @default(cuid())
  workspaceId  String
  workspace    Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  websiteId    String?
  website      Website?                @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  scanId       String?
  scan         Scan?                   @relation(fields: [scanId], references: [id], onDelete: SetNull)
  channelType  NotificationChannelType
  recipient    String
  subject      String
  status       NotificationStatus      @default(PENDING)
  sentAt       DateTime?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime                @default(now())

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("notification")
}

// ---------- Billing (Phase 8 — Dodo Payments) ----------

model Subscription {
  id                 String    @id @default(cuid())
  workspaceId        String    @unique
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Entitlement source of truth: "free" | "pro". Set by verified webhooks.
  planId             String    @default("free")
  // Provider status string (dodo): active | on_hold | cancelled | expired | failed | pending.
  status             String    @default("active")
  provider           String    @default("dodo")
  dodoCustomerId     String?
  dodoSubscriptionId String?   @unique
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  // Logical time of the last applied webhook event — guards against
  // out-of-order/retried delivery re-applying a stale transition.
  lastEventAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([dodoCustomerId])
  @@map("subscription")
}

// Server-issued, unguessable checkout attribution (Phase 8 security).
// Stamped into checkout metadata so a webhook can map a payment back to the
// workspace WITHOUT trusting a client-editable workspace id.
model CheckoutIntent {
  id          String    @id @default(cuid())
  token       String    @unique
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  // What the buyer is checking out: "pro" (base plan) | "website_addon".
  // Travels with the server-issued intent so the webhook never trusts the
  // client to say which product was purchased.
  kind        String    @default("pro")
  consumedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@map("checkout_intent")
}

// A recurring website-capacity add-on (Phase 8.1). Each active row grants
// `websitesGranted` extra websites on top of the Pro base. A workspace can hold
// many, each its own Dodo subscription — buying "30 more" again just adds a row.
model WebsiteAddon {
  id                 String    @id @default(cuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dodoSubscriptionId String    @unique
  dodoCustomerId     String?
  // Provider status; only "active" grants capacity.
  status             String    @default("active")
  websitesGranted    Int       @default(30)
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  // Logical time of the last applied webhook event — out-of-order guard.
  lastEventAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([workspaceId])
  @@index([dodoCustomerId])
  @@map("website_addon")
}

// Webhook idempotency (spec §38): every processed event id is recorded once.
model ProcessedWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  eventType   String
  processedAt DateTime @default(now())

  @@map("processed_webhook_event")
}

// ---------- Blog (built-in mini-CMS for SEO content) ----------

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  excerpt        String?
  // Markdown source — rendered with react-markdown (raw HTML stays escaped).
  content        String
  status         BlogPostStatus @default(DRAFT)
  // Set on first publish, preserved across unpublish/re-publish cycles.
  publishedAt    DateTime?
  authorName     String         @default("Fluxen Team")
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status, publishedAt])
  @@map("blog_post")
}

// ---------- Waitlist (migrated from Phase 0 file store) ----------

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("unknown")
  createdAt DateTime @default(now())

  @@map("waitlist_entry")
}

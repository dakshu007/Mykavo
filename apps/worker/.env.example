# PostgreSQL connection — same database as the web app (pg-boss uses its own schema)
DATABASE_URL=postgresql://user@localhost:5432/fluxen_dev

# Where screenshots/artifacts are written. Must match the web app's ARTIFACT_DIR.
ARTIFACT_DIR=/absolute/path/to/repo/.data/artifacts

# Scheduler cron (spec §40). Default: every 5 minutes. The sweep only enqueues
# scans for websites whose nextScanAt is due, so a frequent cron is cheap.
SCHEDULER_CRON=*/5 * * * *

# Retention sweep cron (spec §60/§91). Default: daily at 03:00 UTC. Deletes
# expired snapshots + artifacts + change events per each workspace's plan window
# (30d Free / 365d Pro). Baseline-referenced snapshots are never deleted.
RETENTION_CRON=0 3 * * *

# Weekly report cron (spec §37 client-ready reports). Default: Mondays 08:00
# UTC. Sends one client-forwardable summary email per ACTIVE website covering
# the last 7 days (scans, changes by severity, uptime, SSL, Lighthouse).
REPORT_CRON=0 8 * * 1

# Weekly Lighthouse audit sweep. Default: Tuesdays 06:00 UTC — offset from the
# Monday report sweep so audits and report emails never contend. Enqueues one
# homepage audit per ACTIVE website (skipping any audited in the last 5 days);
# a performance score falling >=15 points vs the previous audit (from a
# baseline >=30) triggers a performance-drop alert email.
AUDIT_CRON=0 6 * * 2

# Base URL used in notification email links.
APP_URL=http://localhost:3000

# Email delivery. Without RESEND_API_KEY, emails are logged (console provider)
# in development — the pipeline works with no account. Set the key to send via
# Resend's free tier. EMAIL_FROM must be a verified sender (or Resend's
# onboarding@resend.dev for testing).
# RESEND_API_KEY=
# EMAIL_FROM=MyKavo <onboarding@resend.dev>
# EMAIL_PROVIDER=console

# Artifact storage backend. Default: local disk at ARTIFACT_DIR.
# Production: "r2" — screenshots/diffs/avatars/blog images live in Cloudflare
# R2 (S3-compatible; token scoped to one bucket with Object Read & Write).
# ARTIFACT_STORE=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=mykavo
# Legacy backend: "netlify-blobs" (with NETLIFY_SITE_ID + NETLIFY_AUTH_TOKEN).
# ARTIFACT_STORE=netlify-blobs
# NETLIFY_SITE_ID=
# NETLIFY_AUTH_TOKEN=

# PostgreSQL connection — same database as the web app (pg-boss uses its own schema)
DATABASE_URL=postgresql://user@localhost:5432/fluxen_dev

# Where screenshots/artifacts are written. Must match the web app's ARTIFACT_DIR.
ARTIFACT_DIR=/absolute/path/to/repo/.data/artifacts

# Scheduler cron (spec §40). Default: every 5 minutes. The sweep only enqueues
# scans for websites whose nextScanAt is due, so a frequent cron is cheap.
SCHEDULER_CRON=*/5 * * * *

# Retention sweep cron (spec §60/§91). Default: daily at 03:00 UTC. Deletes
# expired snapshots + artifacts + change events per each workspace's plan window
# (30d Free / 365d Pro). Baseline-referenced snapshots are never deleted.
RETENTION_CRON=0 3 * * *

# Base URL used in notification email links.
APP_URL=http://localhost:3000

# Email delivery. Without RESEND_API_KEY, emails are logged (console provider)
# in development — the pipeline works with no account. Set the key to send via
# Resend's free tier. EMAIL_FROM must be a verified sender (or Resend's
# onboarding@resend.dev for testing).
# RESEND_API_KEY=
# EMAIL_FROM=Fluxen <onboarding@resend.dev>
# EMAIL_PROVIDER=console

# MyKavo web app environment (see src/lib/env.ts for validation).
# Copy to .env.local and fill in real values. Never commit secrets.

# PostgreSQL connection.
DATABASE_URL=postgresql://user@localhost:5432/fluxen_dev

# Better Auth (min 32 chars). Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-random-32-character-secret
# BETTER_AUTH_URL=http://localhost:3000

# Public base URL used in metadata/links.
# APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth (optional).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Blog mini-CMS admin allowlist (optional). Comma-separated, case-insensitive
# emails allowed to write and publish blog posts from /dashboard/blog.
# Leave unset to disable the CMS entirely.
# BLOG_ADMIN_EMAILS=you@example.com,teammate@example.com

# Dodo Payments (optional — billing degrades gracefully when unset).
# DODO_PRODUCT_ID=
# DODO_WEBHOOK_SECRET=
# DODO_API_KEY=
# DODO_MODE=test

# Artifact storage (screenshots/diffs/avatars/blog images). Production: R2.
# ARTIFACT_STORE=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=mykavo

# New-signup export to the marketing Google Sheet (Apps Script web app URL).
# Unset = disabled; user emails always remain in Postgres regardless.
# SIGNUP_SHEET_WEBHOOK_URL=
